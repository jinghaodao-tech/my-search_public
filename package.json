{
  "name": "digital-commons-bm25",
  "version": "1.0.0",
  "description": "デジタル・コモンズ BM25スコアリングエンジン",
  "type": "module",
  "scripts": {
    "start": "npx tsx server.ts",
    "dev": "npx tsx --watch server.ts",
    "typecheck": "tsc --noEmit",
    "migrate:tokens": "tsx scripts/regenerate_card_tokens.ts",
    "backfill:tokens": "tsx scripts/backfill_card_tokens.ts",
    "backfill:article-tokens": "tsx scripts/backfill_article_tokens.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "kuromoji": "^0.1.2",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0",
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/kuromoji": "^0.1.3",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "typescript": "^6.0.3"
  }
}
